# ── Input files (read-only) ──────────────────────────────────────────────────
FORM_PDF=inputs/form_fillable.pdf
DEMOGRAPHICS_JSON=inputs/demographics.json
SOAP_NOTES_TXT=inputs/soap_notes.txt
LAB_RESULT_PDF=inputs/lab_result.pdf

# ── Output files (generated) ─────────────────────────────────────────────────
SCHEMA_JSON=outputs/schema.json
ANSWERS_JSON=outputs/answers.json
OUTPUT_PDF=outputs/populated.pdf

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console  # console | json

# ── Confidence scores ─────────────────────────────────────────────────────────
DEMOGRAPHICS_CONFIDENCE=0.95
SOAP_CONFIDENCE=0.75
LAB_CONFIDENCE=0.70

# ── LLM settings ─────────────────────────────────────────────────────────────
USE_LLM_FALLBACK=true
MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
MODEL_CACHE_DIR=./models/Qwen2.5-3B-Instruct
MAX_INPUT_TOKENS=2048
MAX_NEW_TOKENS=450

# ── OCR settings ─────────────────────────────────────────────────────────────
USE_OCR_FALLBACK=true
OCR_DPI=200
